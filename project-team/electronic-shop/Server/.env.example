# Cổng backend
PORT=8080

# MongoDB local hoặc MongoDB Atlas
MONGO_URI=mongodb://127.0.0.1:27017/electronic_shop
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# Địa chỉ frontend được phép gọi API
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Gmail/Nodemailer dùng gửi OTP và email đơn hàng
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ZaloPay Sandbox
ZALOPAY_APP_ID=your_zalopay_app_id
ZALOPAY_KEY1=your_zalopay_key1
ZALOPAY_KEY2=your_zalopay_key2
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_QUERY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/query

# Khi chỉ chạy localhost có thể để trống.
# Muốn nhận callback tự động, dùng URL public như ngrok trỏ vào backend cổng 8080.
ZALOPAY_CALLBACK_URL=

# VietQR chuyển khoản ngân hàng
BANK_TRANSFER_BANK_ID=MB
BANK_TRANSFER_ACCOUNT_NO=your_account_number
BANK_TRANSFER_ACCOUNT_NAME=YOUR_ACCOUNT_NAME
BANK_TRANSFER_TEMPLATE=compact2
